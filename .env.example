# ─────────────────────────────────────────────────────────────────────────────
# .env.local  —  LOCAL DEVELOPMENT ONLY
# ─────────────────────────────────────────────────────────────────────────────
# This file is git-ignored. Never commit real secrets.
# Copy this file to .env.local and fill in your TEST mode keys.
#
# TEST keys from: https://dashboard.razorpay.com → Account & Settings → API Keys
# Make sure you're in TEST MODE when generating these.
#
# In production, set these in: Vercel Dashboard → Project → Settings → Environment Variables

# ── Razorpay TEST keys (start with rzp_test_) ────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# ── Webhook secret ────────────────────────────────────────────────────────────
# Set this to any strong random string.
# Then use the SAME value when creating your webhook in the Razorpay dashboard:
#   Dashboard → Developers → Webhooks → Add New Webhook → Secret
# Generate a good one: openssl rand -hex 32
RAZORPAY_WEBHOOK_SECRET=replace_with_a_strong_random_string_min_32_chars

# ── Node environment ──────────────────────────────────────────────────────────
NODE_ENV=development
